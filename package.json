{
  "name": "german-law-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "LLM-friendly German federal legislation MCP server powered by NeuRIS",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/worker.mjs --loader:.html=text --loader:.css=text --loader:.txt=text --external:cloudflare:workers",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "docs:check": "vitest run tests/catalog.test.ts",
    "deploy": "npm run build && node scripts/deploy-worker-api.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.29",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260712.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
